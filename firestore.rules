rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
        request.auth.token.email == 'mr074770@gmail.com' && 
        request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        request.auth.token.email_verified == true && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // --- Validation Blueprints ---

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'permissions'])
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.permissions is list && data.permissions.size() <= 20
        && (data.get('createdAt', request.time) is timestamp);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'address', 'phoneNumber', 'items', 'size', 'shippingLocation', 'totalPrice', 'status', 'createdAt'])
        && data.keys().size() == 9
        && data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 100
        && data.address is string && data.address.size() >= 5 && data.address.size() <= 500
        && data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 20
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.size is string && data.size in ['S', 'M', 'L', 'XL', 'XXL']
        && data.shippingLocation is string && data.shippingLocation in ['inside_dhaka', 'outside_dhaka']
        && data.totalPrice is number && data.totalPrice > 0
        && data.status == 'pending'
        && data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'regularPrice', 'image'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price > 0
        && data.regularPrice is number && data.regularPrice >= 0
        && data.image is string && data.image.size() > 0 && data.image.size() <= 1000
        && (data.get('color', '') is string && data.get('color', '').size() <= 100)
        && (data.get('priority', 'normal') is string && data.get('priority', 'normal') in ['high', 'medium', 'normal'])
        && (data.get('createdAt', request.time) is timestamp);
    }

    function isValidAppSettings(data) {
      return data.keys().hasAny(['metaPixelId', 'updatedAt'])
        && (data.get('metaPixelId', '') is string && data.get('metaPixelId', '').size() <= 100);
    }

    // --- Collection Routes ---

    // Admins Collection
    match /admins/{email} {
      allow get: if isSuperAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() && isValidAdmin(incoming()) && incoming().createdAt == request.time;
      allow update: if isSuperAdmin() && isValidAdmin(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSuperAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if (isAdmin() || isValidOrder(incoming()));
      
      // Admin Access
      allow read, update, delete: if isAdmin(); 
    }

    // Products Collection
    match /products/{productId} {
      // Public Read
      allow get, list: if true;
      
      // Admin Write
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    // Settings Collection
    match /settings/{configId} {
      // Public Read (e.g. for Meta Pixel)
      allow get: if configId == 'config';
      allow list: if false; // Deny listing settings
      
      // Admin Write
      allow write: if isAdmin() && configId == 'config' && isValidAppSettings(incoming());
    }
  }
}
